# ============================================
# ODOLO BOT - Environment Variables
# ============================================

# --- Core ---
PORT=3000
OWNER_NAME=Charles
OWNER_STYLE=friendly, casual, concise
PUBLIC_URL=https://your-railway-url.railway.app

# --- AI ---
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Telegram ---
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
OWNER_TELEGRAM_CHAT_ID=your-personal-chat-id

# --- Meta (WhatsApp + Facebook + Instagram) ---
# console.developers.facebook.com
META_ACCESS_TOKEN=your-meta-token
META_VERIFY_TOKEN=any-string-you-choose
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# --- TikTok ---
# developers.tiktok.com (requires approval)
TIKTOK_ACCESS_TOKEN=your-tiktok-token

# --- Email ---
# EMAIL_PROVIDER: gmail | yahoo | outlook | icloud | zoho
EMAIL_PROVIDER=gmail
EMAIL_ADDRESS=you@gmail.com
EMAIL_APP_PASSWORD=your-app-password

# --- Google (Calendar) ---
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token

# --- Weather ---
OPENWEATHER_API_KEY=your-key

# --- News ---
NEWS_API_KEY=your-key

# --- Music (Android ADB) ---
MUSIC_DEVICE=android

# --- Smart Home ---
HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=your-token

# --- Database (optional but recommended) ---
DATABASE_URL=postgresql://user:password@host:5432/odolo
REDIS_URL=redis://localhost:6379
