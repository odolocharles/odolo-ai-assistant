    "imap":              "^0.8.19",
    "mailparser":        "^3.7.0",
    "pg":                "^8.11.0",
    "redis":             "^4.6.0",
    "node-fetch":        "^3.3.0"
  },
  "devDependencies": {
    "@types/express":    "^4.17.0",
    "@types/node":       "^20.12.0",
    "@types/nodemailer": "^6.4.0",
    "@types/pg":         "^8.11.0",
    "typescript":        "^5.4.0",
    "ts-node-dev":       "^2.0.0"
